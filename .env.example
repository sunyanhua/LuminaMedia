# Database Configuration (阿里云 RDS)
DB_HOST=your-rds-host.rds.aliyuncs.com
DB_PORT=3306
DB_USERNAME=your_username
DB_PASSWORD=your_password
DB_DATABASE=lumina_media

# TypeORM Settings
TYPEORM_SYNCHRONIZE=false
TYPEORM_LOGGING=true
TYPEORM_ENTITIES=src/entities/**/*.entity.ts
TYPEORM_MIGRATIONS=src/migrations/**/*.ts
TYPEORM_SUBSCRIBERS=src/subscribers/**/*.ts

# Application Settings
APP_PORT=3003
APP_ENV=development

# JWT Secret (for future authentication)
JWT_SECRET=your_jwt_secret_key_here

# Google Gemini API Configuration
# Support multiple API keys separated by commas to bypass rate limits
# Example: GEMINI_API_KEY=key1,key2,key3
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=2048
GEMINI_TOP_P=0.95
GEMINI_TOP_K=40
# API Key轮询模式: sequential (顺序) 或 random (随机)
GEMINI_KEY_ROTATION=sequential

# 阿里云通义千问配置
DASHSCOPE_API_KEY=your_dashscope_api_key_here
QWEN_MODEL=qwen-max
QWEN_TEMPERATURE=0.7
QWEN_MAX_TOKENS=2048