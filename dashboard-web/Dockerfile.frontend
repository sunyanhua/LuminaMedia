# Development stage
FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./
COPY tsconfig*.json ./
COPY vite.config.ts ./
COPY tailwind.config.js ./
COPY postcss.config.js ./
COPY components.json ./

# Install dependencies
RUN npm install

# Expose port for development server
EXPOSE 5174

# Start development server with hot reload
CMD ["npm", "run", "dev", "--", "--port", "5174", "--host", "0.0.0.0"]