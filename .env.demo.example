# LuminaMedia DEMO环境变量配置文件
# 复制此文件为 .env.demo 并填写实际值

# ====================
# AI服务配置
# ====================

# Google Gemini API配置
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=2048
GEMINI_TOP_P=0.95
GEMINI_TOP_K=40

# 阿里云百炼（Qwen）配置
DASHSCOPE_API_KEY=your_dashscope_api_key_here
QWEN_MODEL=qwen-max
QWEN_TEMPERATURE=0.7
QWEN_MAX_TOKENS=2048

# ====================
# 数据库配置
# ====================

# 商务版DEMO数据库
DB_DEMO_HOST=db-demo
DB_DEMO_PORT=3306
DB_DEMO_USERNAME=demo_user
DB_DEMO_PASSWORD=demo_password
DB_DEMO_DATABASE=lumina_demo

# 政务版DEMO数据库
DB_GOV_HOST=db-gov
DB_GOV_PORT=3306
DB_GOV_USERNAME=gov_user
DB_GOV_PASSWORD=gov_password
DB_GOV_DATABASE=lumina_gov

# ====================
# 应用配置
# ====================

# 演示模式配置
DEMO_MODE_ENABLED=true
DEMO_DATA_SOURCE=mock  # mock 或 real
DEMO_AI_PROVIDER=mock  # mock, gemini, 或 qwen

# 前端配置
VITE_API_BASE_URL=/
VITE_DEMO_MODE=true
VITE_BUSINESS_API_URL=http://localhost:3004
VITE_GOVERNMENT_API_URL=http://localhost:3005

# ====================
# 安全配置
# ====================

# JWT配置
JWT_SECRET=demo_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# 加密密钥（用于凭证加密）
ENCRYPTION_KEY=32_byte_encryption_key_for_demo_only

# ====================
# 社交媒体API配置（政务版真实账号）
# ====================

# 微信公众号
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# 微博
WEIBO_APP_KEY=your_weibo_app_key
WEIBO_APP_SECRET=your_weibo_app_secret

# 小红书
XIAOHONGSHU_APP_KEY=your_xiaohongshu_app_key
XIAOHONGSHU_APP_SECRET=your_xiaohongshu_app_secret

# 抖音
DOUYIN_APP_KEY=your_douyin_app_key
DOUYIN_APP_SECRET=your_douyin_app_secret

# ====================
# 监控配置
# ====================

# APM监控
APM_ENABLED=true
APM_SERVICE_NAME=lumina-demo
APM_SERVICE_INSTANCE=lumina-demo-instance-1
APM_OAP_SERVER=http://skywalking-oap:12800

# 日志配置
LOG_LEVEL=info
LOG_DIR=/app/logs

# ====================
# 代理配置（如果需要）
# ====================

# HTTPS_PROXY=http://host.docker.internal:7897
# HTTP_PROXY=http://host.docker.internal:7897